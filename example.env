# ─── CREDENZIALI OBBLIGATORIE ───────────────────────────────────────
CF=                # Codice Fiscale dell'utente (tuo CF)
PIN=               # PIN Entratel/Fisconline
PASSWORD=          # Password Entratel/Fisconline

# ─── IMPOSTAZIONI OPZIONALI (hanno default in codice) ──────────────
# DATA_DAL=01/01/2025   # Data inizio (default: 01/01/anno corrente)
# DATA_AL=31/12/2025    # Data fine   (default: 31/12/anno corrente)
# PIVA=                 # Partita IVA target
# UTENZA=2              # 1: MeStesso, 2: Delega Diretta, 3: Incaricato
# DB=1                  # Salva nel DB (default: 0)
# WRITE=1               # Mantieni file su disco (default: 1)
# CORRISPETTIVI=0       # Scarica corrispettivi (default: 0)
# TRANSFRONTALIERE=0    # Scarica transfrontaliere (default: 0)
# FEC_CA_BUNDLE=        # Path a bundle CA personalizzato

# ─── FILE CSV DELEGHE DIRETTE ───────────────────────────────────────
# DELEGHE_FILE=%~/.fec_ade/deleghe.csv

# ─── DATABASE (opzionale) ──────────────────────────────────────────
# DB_TYPE=sqlite
# DB_SQLITE_PATH=output/fatture_v3.db
